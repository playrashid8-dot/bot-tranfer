# Required — never commit real values
PRIVATE_KEY=your_wallet_private_key_without_0x_prefix

BSC_RPC_URL=https://bsc-mainnet.nodereal.io/v1/f39fd51271c447d695969c5152cb61dd

BSC_RPC_FALLBACKS=https://bsc-dataseed1.binance.org/,https://bsc.publicnode.com

TOKEN_ADDRESS=0x1dF5b60a0045c2b8221ADAa3a982778157E70749

# Optional
# Optional — comma-separated token list override (defaults to built-in watch list)
# WATCH_TOKENS=
BSCSCAN_API_KEY=
DRY_RUN=false

# Rate limits (defaults shown)
MAX_WALLETS_PER_DAY=100
MAX_WALLETS_PER_HOUR=10
MIN_BNB_BALANCE=0.005
RETRY_LIMIT=3
SCAN_BLOCK_RANGE=200

# Distribution amounts are fixed presets — do not change unless you understand the impact
# Allowed: 0.1, 0.2, 0.4, 0.5, 0.8, 1.4, 1.7, 2.0
